---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodexDemoDashboard from "../../components/demo/codex/CodexDemoDashboard.svelte";
import CodexDemoLeadsFlow from "../../components/demo/codex/CodexDemoLeadsFlow.svelte";
import CodexDemoChat from "../../components/demo/codex/CodexDemoChat.svelte";

const branding = {
  displayName: "Vertice360 Demo",
  logoUrl: "/logo_v360.png",
  primaryColor: "#0F766E",
  secondaryColor: "#FBBF24",
  accentColor: "#115E59",
};
---

<!-- DEMO – Página con dashboard + chat conversacional (NO PRODUCCIÓN) -->
<BaseLayout brand={branding}>
  <div class="bg-[var(--bg-card-secondary)] rounded-2xl p-6 space-y-4">
    <section class="space-y-2 mb-8">
      <p class="text-sm uppercase tracking-wide text-emerald-700 font-semibold">
        Demo Vertice360
      </p>
      <h1 class="">Inventario en pozo con copiloto conversacional</h1>
      <p class="">
        Explorá proyectos, unidades e inversores con datos ficticios y probá el
        chat que responde al instante sobre el inventario. Pensado para mostrar
        el flujo comercial de Vertice360 end-to-end.
      </p>
    </section>

    <section class="grid gap-8 xl:grid-cols-[2fr,1fr]">
      <div class="space-y-8">
        <CodexDemoDashboard client:load />
        <CodexDemoLeadsFlow client:load />
      </div>
      <CodexDemoChat client:load />
    </section>
  </div>
</BaseLayout>
