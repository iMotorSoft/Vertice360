---
import BaseLayout from "../layouts/BaseLayout.astro";

const branding = {
  displayName: "Vertice360",
  logoUrl: "/logo-placeholder.svg",
  primaryColor: "#0F766E",
  secondaryColor: "#FBBF24",
  accentColor: "#115E59",
};

const demoUrl = "/demo/modal";
const highlights = [
  {
    title: "Inventario en pozo, claro y navegable",
    desc: "Recorre proyectos, unidades y relacionamiento con inversores usando datos ficticios ya cargados.",
  },
  {
    title: "Simulá el flujo Lead-to-Reserva",
    desc: "Combina inversor, proyecto y unidad para ver cómo se arma un caso comercial en segundos.",
  },
  {
    title: "Copiloto conversacional integrado",
    desc: "Pregunta en lenguaje natural sobre lo que ves en el dashboard y obtené respuestas con IDs y montos.",
  },
];

const sampleQuestions = [
  "¿Qué unidades de 3 ambientes están disponibles en PZ-ALV-101?",
  "Mostrame las reservas confirmadas y quién las hizo.",
  "¿Cuál es el rango de precios de Torre Alvear?",
  "Dame una unidad disponible en preventa y su monto de lista.",
];
---

<BaseLayout brand={branding}>
  <div class="bg-[var(--bg-card-secondary)] rounded-2xl p-6 space-y-4">
    <section class="grid gap-8 lg:grid-cols-2 items-center mb-12">
      <div class="space-y-4">
        <p
          class="text-sm uppercase tracking-wide --text-secondary font-semibold"
        >
          {branding.displayName} · Demo conversacional
        </p>
        <h1 class="leading-tight">
          Inventario en pozo con copiloto de ventas integrado
        </h1>
        <p class="text-lg --text-secondary">
          Navegá el pipeline comercial de punta a punta con datos demo:
          proyectos, unidades, inversores y operaciones. Consulta todo en
          lenguaje natural con el chat integrado y probá cómo se acelera la toma
          de decisión.
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a class="btn btn-primary" href={demoUrl}>
            Ver demo conversacional
          </a>
          <a class="btn btn-secondary" href="/demo"> Ver dashboard clásico </a>
        </div>
        <div class="flex flex-wrap gap-3 text-sm --text-secondary">
          <span class="badge badge-ghost">Lead-to-Reserva</span>
          <span class="badge badge-ghost">Inventario en pozo</span>
          <span class="badge badge-ghost">Copiloto</span>
        </div>
      </div>
      <div class="card-primary p-6 space-y-4">
        <div class="flex items-center gap-2">
          <span class="badge badge-outline border-emerald-200 --text-primary"
            >Qué podés hacer</span
          >
        </div>
        <ul class="space-y-3">
          {
            highlights.map((item) => (
              <li class="flex gap-3">
                <div class="mt-1 h-2 w-2 rounded-full bg-emerald-300" />
                <div>
                  <p class="font-semibold">{item.title}</p>
                  <p class=" text-sm">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="grid gap-8 lg:grid-cols-3 mb-12">
      <div class="lg:col-span-2 card">
        <div class="card-body space-y-3">
          <p
            class="text-xs uppercase tracking-wide text-emerald-700 font-semibold"
          >
            Cómo funciona la demo
          </p>
          <h2 class="card-title text-2xl">
            Explorá el tablero y preguntá lo que ves
          </h2>
          <p class="text-neutral-700">
            En la demo vas a encontrar un dashboard con proyectos en pozo, sus
            unidades y la relación con inversores. El chat entiende ese mismo
            inventario y responde con IDs, montos y estados tal como aparecen en
            pantalla.
          </p>
          <div class="grid md:grid-cols-3 gap-3 text-sm text-neutral-700">
            <div class="p-3 card-primary border border-base-200">
              <p class="font-semibold text-emerald-800">
                1) Recorre el inventario
              </p>
              <p>
                Seleccioná un proyecto y revisá unidades, precios y estado
                comercial.
              </p>
            </div>
            <div class="p-3 card-primary border border-base-200">
              <p class="font-semibold text-emerald-800">
                2) Simulá una reserva
              </p>
              <p>
                Combina inversor, proyecto y unidad para ver un caso de
                Lead-to-Reserva.
              </p>
            </div>
            <div class="p-3 card-primary border border-base-200">
              <p class="font-semibold text-emerald-800">
                3) Preguntá al copiloto
              </p>
              <p>
                Escribí en el chat y obtené respuestas inmediatas sobre lo que
                ves en el tablero.
              </p>
            </div>
          </div>
        </div>
      </div>
      <div class="card-primary p-2">
        <div class="card-body space-y-3">
          <p
            class="text-xs uppercase tracking-wide text-emerald-700 font-semibold"
          >
            Ejemplos para el chat
          </p>
          <ul class="space-y-2 text-sm text-neutral-700">
            {
              sampleQuestions.map((q) => (
                <li class="p-3 rounded-lg border border-base-300 bg-[var(--bg-card)]">
                  {q}
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
