---
import "../styles/base.css";

const brand = Astro.props.brand ?? {
  displayName: "Estudio Demo",
  logoUrl: "/logo_v360.png",
};
---

<!doctype html>
<html lang="es" data-theme="vertice360">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vertice360</title>
  </head>
  <body class="bg-[var(--bg-card-secondary)] text-base-content min-h-screen">
    <header class="bg-white/90 shadow-lg shadow-gray-300/20 backdrop-blur">
      <div class="container mx-auto px-4 py-4 flex items-center gap-3">
        <img
          src={brand.logoUrl || "/logo_v360.png"}
          alt="Logo"
          class="h-10 w-10 rounded"
          loading="lazy"
        />
        <div class="flex flex-col">
          <span class="font-semibold text-lg">{brand.displayName}</span>
          <span class="text-sm text-neutral-500">Vertice360</span>
        </div>
      </div>
    </header>
    <main class="container mx-auto px-4 py-8">
      <slot />
    </main>
  </body>
</html>
